# Copy this file to .env before starting the stack.
#
# Option A: Ollama on the host
# OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Option B: Ollama in Docker Compose
# OLLAMA_BASE_URL=http://ollama:11434

OPEN_WEBUI_PORT=3000
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OLLAMA_IMAGE=ollama/ollama:latest

# Replace this with a real secret before exposing Open WebUI beyond a trusted LAN.
WEBUI_SECRET_KEY=change-me

# Open WebUI backend mode:
# - Direct Ollama mode:
#   ENABLE_OLLAMA_API=true
#   ENABLE_OPENAI_API=false
# - Router mode (recommended after the router service is running):
#   ENABLE_OLLAMA_API=false
#   ENABLE_OPENAI_API=true
ENABLE_OLLAMA_API=false
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://host.docker.internal:8788/v1
OPENAI_API_KEY=local-ai-node
ENABLE_BASE_MODELS_CACHE=true

# Backup settings for the helper scripts.
# This can point to a NAS mount, an external disk, or any other backup path.
BACKUP_ROOT_DIR=/mnt/nas/local-ai-node/ollama-backups
OLLAMA_HOME_DIR=$HOME/.ollama

# Optional override for the connectivity script.
OPEN_WEBUI_URL=http://localhost:3000

# RAG defaults for the local JSON-backed retrieval scripts.
RAG_DOCUMENTS_DIR=rag-data/documents
RAG_INDEX_DIR=rag-data/chroma
RAG_EMBED_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.1:8b
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4

# Router service defaults.
ROUTER_SERVICE_HOST=127.0.0.1
ROUTER_SERVICE_PORT=8788
ROUTER_DEFAULT_MODEL=llama3.1:8b
ROUTER_CODE_MODEL=deepseek-coder:6.7b
ROUTER_LIGHT_MODEL=phi3
ROUTER_RAG_MODEL=gemma4:31b

# Idea capture service defaults.
OLLAMA_URL=http://host.docker.internal:11434
IDEA_CAPTURE_HOST=127.0.0.1
IDEA_CAPTURE_PORT=8790
IDEA_CAPTURE_MODEL=llama3.1:8b
IDEA_CAPTURE_NOTES_DIR=notes/idea-inbox
# Set this before exposing the capture endpoint beyond your local machine.
IDEA_CAPTURE_API_TOKEN=
